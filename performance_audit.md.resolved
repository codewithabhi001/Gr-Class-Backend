### Fix 2: Cache Auth Middleware User Lookup 🔴

```javascript
// Simple in-memory cache for auth middleware
const userCache = new Map();
const USER_CACHE_TTL = 60_000;

// In authenticate():
const cached = userCache.get(decoded.id);
if (cached && Date.now() - cached.ts < USER_CACHE_TTL) {
    if (cached.user.status !== 'ACTIVE') { return 401; }
    req.user = cached.user;
    return next();
}
const user = await db.User.findByPk(decoded.id);
userCache.set(decoded.id, { user, ts: Date.now() });
```

### Fix 3: Cache S3 Signed URLs 🟡

```javascript
// In fileAccess.service.js
const signedUrlCache = new Map();
const SIGNED_URL_CACHE_TTL = 3000_000; // 50 min (URLs valid for 60 min)

export const generateSignedUrl = async (key, expiresInSeconds = 3600, user = null) => {
    const cacheKey = `${key}:${expiresInSeconds}`;
    const cached = signedUrlCache.get(cacheKey);
    if (cached && Date.now() - cached.ts < SIGNED_URL_CACHE_TTL) {
        return cached.url;
    }
    
    const signedUrl = await s3Service.getSignedFileUrl(key, expiresInSeconds);
    signedUrlCache.set(cacheKey, { url: signedUrl, ts: Date.now() });
    return signedUrl;
};
```

### Fix 4: Optimize Login Flow 🔴

```javascript
// BEFORE: 4 sequential DB calls + bcrypt
export const login = async (email, password) => {
    const user = await User.findOne({ where: { email } });         // Query 1
    const isMatch = await bcrypt.compare(password, user.password_hash); // CPU ~300ms
    await user.update({ last_login_at: new Date() });              // Query 2
    const resolvedUser = await fileAccessService.resolveEntity(user); // Query 3 (S3)
    return { user: userObj, accessToken, refreshToken };
};

// AFTER: Minimize blocking operations
export const login = async (email, password) => {
    const user = await User.findOne({ where: { email } });        // Query 1
    const isMatch = await bcrypt.compare(password, user.password_hash); // CPU
    
    // Non-blocking update — don't await
    user.update({ last_login_at: new Date() }).catch(() => {});
    
    // Skip resolveEntity for login — profile_pic_url can be a CDN URL
    const profilePicUrl = user.profile_pic_url?.startsWith('public/')
        ? fileAccessService.generatePublicCdnUrl(user.profile_pic_url)
        : user.profile_pic_url; // Return key, let frontend request signed URL when needed
    
    return {
        user: { id: user.id, name: user.name, email: user.email, role: user.role, profile_pic_url: profilePicUrl },
        accessToken: generateAccessToken(user),
        refreshToken: generateRefreshToken(user),
    };
};
```

### Fix 5: Fix N+1 in Job Workflow Functions 🟡

```javascript
// BEFORE — Every workflow function:
const job = await requireJob(id);                                    // Query 1
// ... business logic ...
const jobWithVessel = await JobRequest.findByPk(id, { include: ['Vessel'] }); // Query 2

// AFTER — Load vessel upfront:
const requireJob = async (id, includeVessel = false) => {
    const include = includeVessel ? ['Vessel'] : [];
    const job = await JobRequest.findByPk(id, { include });
    if (!job) throw { statusCode: 404, message: 'Job not found.' };
    return job;
};

// Usage:
const job = await requireJob(id, true); // Single query with vessel
```

