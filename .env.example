# ==========================================
# GR-CLASS BACKEND - ENVIRONMENT VARIABLES
# ==========================================

# --------------------------
# Environment & Server
# --------------------------
NODE_ENV=development
PORT=3000

# --------------------------
# Public URLs
# --------------------------
# The URL where the frontend is hosted (CORS & Footer Links)
FRONTEND_URL=http://localhost:3000

# The Public HTTPS URL for this backend API (CRITICAL FOR GMAIL UNSUBSCRIBE & ABSOLUTE LINKS)
# If using live server, set this to https://api.grclass.com
PUBLIC_API_BASE_URL=http://localhost:3000

# --------------------------
# Database Configuration
# --------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=gr_class_db
DB_DIALECT=mysql
# DB_SSL_CA=path_to_ca_cert.pem

# --------------------------
# Security & Auth (JWT & Bcrypt)
# --------------------------
# MUST set strong random strings for these in production!
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_RESET_SECRET=your_jwt_reset_secret_key_here

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=1h

BCRYPT_SALT_ROUNDS=10

# Security setting for global API rate limiter
GLOBAL_RATE_LIMIT_MAX=400

# --- Token denylist (logout) — REQUIRED for multiple app instances ---
# REDIS_URL=redis://localhost:6379

# --------------------------
# Newsletter & Email Templates
# --------------------------
# Name shown in Gmail "Unsubscribe" native popup
NEWSLETTER_LIST_ID="GR-Class Newsletter"

# Cryptographic secret used to securely sign Unsubscribe one-click tokens. MUST be 32+ chars in prod.
NEWSLETTER_UNSUBSCRIBE_SECRET=a_very_long_random_string_for_unsubscribe_security

# Optional: Override the frontend cancellation landing page URL
# NEWSLETTER_UNSUBSCRIBE_URL=https://grclass.com/newsletter/unsubscribe

# --------------------------
# AWS Configuration (S3, CloudFront)
# --------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_s3_bucket_name
AWS_CLOUDFRONT_DOMAIN=https://your-cloudfront-id.cloudfront.net

# --------------------------
# Email Configuration (Nodemailer / SES)
# --------------------------
# Choose ONE provider: 'smtp' or 'ses'
EMAIL_PROVIDER=smtp

# Default / generic sender (no-reply style). 
FROM_EMAIL="GR-Class" <notify@grclass.com>
# Alternate sender overrides per use-case
EMAIL_FROM_AUTH="GR-Class Security" <auth@grclass.com>
EMAIL_FROM_ALERTS="GR-Class Alerts" <alerts@grclass.com>

# >> If EMAIL_PROVIDER=smtp <<
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# >> If EMAIL_PROVIDER=ses <<
# (Optional) Defaults to AWS_REGION if not provided
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# --------------------------
# Firebase Push Notifications
# --------------------------
# Path to your Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./src/config/gr-class-firebase-adminsdk-fbsvc-9297fb6be9.json
