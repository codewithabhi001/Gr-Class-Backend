# --- App ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=girik_db

# --- JWT (production me strong values) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_RESET_SECRET=

# --- Token denylist (logout) — REQUIRED for multiple app instances ---
# Example: redis://localhost:6379  or  rediss://... (TLS)
REDIS_URL=

# Optional: override global API rate limit (default 400 / 15 min per IP)
# GLOBAL_RATE_LIMIT_MAX=400

# --- AWS (S3 + optional SES; same keys often used for both) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=

# --- Email: choose ONE provider ---
# ses  = Amazon SES (@aws-sdk/client-ses) — FROM address SES me verified hona chahiye
# smtp = Nodemailer (Mailtrap, Gmail SMTP, etc.)
EMAIL_PROVIDER=smtp
# Amazon SES use karne ke liye upar wala line badal kar rakho:
# EMAIL_PROVIDER=ses

#
# --- Amazon SES (jab EMAIL_PROVIDER=ses ho) — setup checklist ---
# 1) SES console me same region rakho jo AWS_REGION / SES_REGION me hai.
# 2) Har domain ya email jo "From" me use karoge — Identity verify karo (Domain recommended + DKIM DNS).
# 3) Sandbox me sirf verified recipients; production ke liye "Request production access".
# 4) IAM user/key par ses:SendEmail allow ho (same keys as S3 agar policy me dono hain).
# 5) Optional: SES_CONFIGURATION_SET for bounce/complaint metrics.
#

# Default / generic sender (no-reply style). Fallback jab purpose-specific set na ho.
# Example: "GIRIK" <noreply@yourdomain.com>
SMTP_FROM=
# Aliases (same value pick one)
FROM_EMAIL=
EMAIL_FROM=

# Optional: alag verified From per use case (SES me har address/domain verify hona chahiye)
# Password reset / auth emails (forgotPassword)
# EMAIL_FROM_AUTH="GIRIK Security" <auth@yourdomain.com>
EMAIL_FROM_AUTH=
# Job alerts & sendTemplateEmail (notifications)
# EMAIL_FROM_ALERTS="GIRIK Alerts" <alerts@otherdomain.com>
EMAIL_FROM_ALERTS=

# Test mail:
#   npm run test:email -- your@email.com
#   npm run test:email -- your@email.com --purpose=auth
#   TEST_EMAIL_PURPOSE=alerts npm run test:email -- your@email.com
# TEST_EMAIL_TO=your@email.com

# Optional: SES event publishing / metrics ke liye Configuration Set name
# SES_CONFIGURATION_SET=your-configuration-set

# SES alag region ho to (warna AWS_REGION use hota hai)
# SES_REGION=

# --- SMTP only (jab EMAIL_PROVIDER smtp ho) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
